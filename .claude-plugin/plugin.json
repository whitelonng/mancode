{
  "name": "mancode",
  "version": "0.1.0-beta.0",
  "description": "AI coding agent workflow harness. Five modes from practice to playoffs: stop over-engineering, reuse project context, and add multi-agent code review.",
  "homepage": "https://github.com/whitelonng/mancode",
  "license": "AGPL-3.0-only",
  "keywords": [
    "yagni",
    "workflow",
    "code-review",
    "multi-agent",
    "design-tokens"
  ],
  "installation": {
    "type": "npm",
    "package": "mancode",
    "postInstall": "mancode init"
  },
  "skills": [
    "skills/solo",
    "skills/man8",
    "skills/man",
    "skills/manteam",
    "skills/manps",
    "skills/mansolo"
  ],
  "agents": [
    "agents/scout.md",
    "agents/head-coach.md",
    "agents/plan-coach.md",
    "agents/film-analyst-offense.md",
    "agents/film-analyst-defense.md"
  ],
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash .mancode/hooks/session-start.sh"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash .mancode/hooks/user-prompt-submit.sh"
      }
    ]
  }
}
